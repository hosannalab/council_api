# Server
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
# En development la API también acepta cualquier localhost:<puerto> (Flutter web).

# Database (PostgreSQL en la nube)
DATABASE_URL=postgresql://user:password@host:5432/council?schema=public

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# SMTP (notificaciones por correo)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
